# ── Gemini API Keys (comma-separated, no spaces) ─────────────────────────────
# Add as many keys as you have. The client rotates to the next key on rate-limit.
GEMINI_API_KEYS=your_gemini_key1,your_gemini_key2

# ── Groq API Keys (comma-separated, no spaces) ────────────────────────────────
# Add as many keys as you have.
GROQ_API_KEYS=your_groq_key1,your_groq_key2
